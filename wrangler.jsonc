{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mywebsite",
  "compatibility_date": "2026-04-06",
  "observability": {
    "enabled": true
  },
  // Build the 11ty site before deploying so `_site` (gitignored) exists.
  // Runs automatically during `wrangler deploy` (Workers Builds deploy command).
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "_site"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
