{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mywebsite",
  "compatibility_date": "2026-04-06",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
- uses: actions/setup-node@v4
  with:
    node-version: '22' # Update to your desired version (e.g., 20, 22, 24)
